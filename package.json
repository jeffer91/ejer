{
  "name": "fitjeff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "description": "FitJeff: app personal local-first para registro corporal, estadisticas, PWA y escritorio Electron.",
  "author": "Jeff",
  "scripts": {
    "dev": "vite --host localhost --port 5173 --strictPort",
    "build": "vite build",
    "preview": "vite preview --host localhost --port 4173 --strictPort",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c green,blue \"npm run dev\" \"wait-on http://localhost:5173/ && cross-env FITJEFF_ELECTRON_DEV=1 electron .\"",
    "electron:build": "npm run build && cross-env FITJEFF_ELECTRON_DEV=0 electron .",
    "electron:dev:check": "npm run tools:check && npm run electron:dev",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:win": "npm run build && electron-builder --win nsis",
    "tools:check": "node scripts/check-tools.cjs",
    "version:bump": "node scripts/version-bump.cjs"
  },
  "dependencies": {
    "electron-updater": "latest",
    "firebase": "^10.14.1"
  },
  "devDependencies": {
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "^41.2.1",
    "electron-builder": "latest",
    "vite": "^5.4.11",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.jeff.fitjeff",
    "productName": "FitJeff",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "jeffer91",
        "repo": "ejer",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
