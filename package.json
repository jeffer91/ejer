{
  "name": "fitjeff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "description": "FitJeff: app personal local-first para registro corporal, estadisticas, PWA y escritorio Electron.",
  "author": "Jeff",
  "scripts": {
    "start": "node scripts/start-electron-dev.cjs",
    "dev": "vite --host localhost --port 5173",
    "build": "vite build",
    "preview": "vite preview --host localhost --port 4173",
    "electron:dev": "node scripts/start-electron-dev.cjs",
    "electron:build": "npm run build && cross-env FITJEFF_ELECTRON_DEV=0 electron .",
    "electron:dev:check": "npm run tools:check && npm run check:structure && npm run audit:app && npm run electron:dev",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:win": "npm run build && electron-builder --win nsis",
    "android:init": "npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "android:apk": "npm run build:android",
    "tools:check": "node scripts/check-tools.cjs",
    "check:structure": "node scripts/check-structure.cjs",
    "check:local": "node scripts/check-local.cjs",
    "audit:app": "node scripts/auditar-app.cjs",
    "version:bump": "node scripts/version-bump.cjs",
    "build:windows": "node scripts/build-windows.cjs",
    "build:android": "npm run build && node scripts/build-android.cjs",
    "release:check": "node scripts/revision-release-final.cjs",
    "release:check:built": "node scripts/revision-release-final.cjs --after-build",
    "release:github": "node scripts/release-github.cjs",
    "review:updates": "node scripts/revision-actualizaciones.cjs",
    "publicar:version": "scripts\\publicar-version.bat",
    "publicar:automatico": "scripts\\publicar-version-automatica.bat",
    "actualizar:todo": "scripts\\actualizar-todo.bat",
    "revisar:todo": "scripts\\revisar-todo.bat"
  },
  "dependencies": {
    "@capacitor/android": "6.2.1",
    "@capacitor/core": "6.2.1",
    "electron-updater": "latest",
    "firebase": "^10.14.1"
  },
  "devDependencies": {
    "@capacitor/cli": "6.2.1",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "^41.2.1",
    "electron-builder": "latest",
    "vite": "^5.4.11",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.jeff.fitjeff",
    "productName": "FitJeff",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "jeffer91",
        "repo": "ejer",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
