/*
  Nombre completo: firestore.rules
  Ruta o ubicación: firestore.rules

  Función:
    - Definir reglas de seguridad para Firestore en FitJeff.
    - Proteger usuarios/jeff y sus subcolecciones.
    - Evitar que la base quede disponible para cualquier visitante.

  Se conecta con:
    - firebase.json
    - src/firebase/firestore.service.js
    - functions/index.js
*/

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isJeffProfile(usuarioId) {
      return usuarioId == "jeff";
    }

    function canUseFitJeff(usuarioId) {
      return signedIn() && isJeffProfile(usuarioId);
    }

    match /usuarios/{usuarioId} {
      allow get, list: if canUseFitJeff(usuarioId);
      allow create, update, delete: if canUseFitJeff(usuarioId);

      match /{collectionId}/{documentId} {
        allow get, list: if canUseFitJeff(usuarioId);
        allow create, update, delete: if canUseFitJeff(usuarioId);
      }
    }

    match /{document=**} {
      allow get, list: if false;
      allow create, update, delete: if false;
    }
  }
}
