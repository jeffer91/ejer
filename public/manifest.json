{
  "projectNotes": {
    "nombreCompleto": "manifest.json",
    "rutaUbicacion": "public/manifest.json",
    "funcionFunciones": [
      "Permitir que FitJeff se instale como PWA en celular y navegador compatible.",
      "Definir nombre, icono, tema, orientación y modo de visualización.",
      "Preparar accesos rápidos de entrenamiento, medidas, reportes y diagnóstico."
    ],
    "seConectaCon": [
      "index.html",
      "service-worker.js",
      "public/version.json",
      "src/pwa/pwa.service.js"
    ],
    "nota": "JSON no permite comentarios reales; esta metadata documenta el archivo sin romper el formato."
  },
  "id": "/",
  "name": "FitJeff",
  "short_name": "FitJeff",
  "description": "App personal para entrenamiento, medidas, reportes, estadísticas y Jarvis.",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "orientation": "portrait-primary",
  "background_color": "#f5f7fb",
  "theme_color": "#111827",
  "categories": [
    "health",
    "fitness",
    "productivity"
  ],
  "lang": "es-EC",
  "dir": "ltr",
  "icons": [
    {
      "src": "/assets/icons/icon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Entrenar",
      "short_name": "Entrenar",
      "description": "Registrar entrenamiento de hoy",
      "url": "/index.html#entrenar"
    },
    {
      "name": "Guiado",
      "short_name": "Guiado",
      "description": "Abrir entrenamiento guiado",
      "url": "/index.html#guiado"
    },
    {
      "name": "Medidas",
      "short_name": "Medidas",
      "description": "Registrar medidas semanales",
      "url": "/index.html#medidas"
    },
    {
      "name": "Reportes",
      "short_name": "Reportes",
      "description": "Generar reportes de progreso",
      "url": "/index.html#reportes"
    },
    {
      "name": "Diagnóstico",
      "short_name": "Diagnóstico",
      "description": "Revisar estado de la app",
      "url": "/index.html#diagnostico"
    }
  ]
}
