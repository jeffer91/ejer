# FitJeff - variables locales de ejemplo
# Copia este archivo como .env.local si quieres activar Firebase en tu PC.
# No subas .env ni .env.local al repositorio.

# Modo recomendado por defecto: local.
VITE_FIREBASE_ENABLED=false

# Completar solo si Firebase se va a usar como respaldo real.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Rutas lógicas dentro de Firestore.
VITE_FIREBASE_COLLECTION=fitjeff
VITE_FIREBASE_USER_DOCUMENT=jeff
VITE_FIREBASE_REGISTROS_SUBCOLLECTION=registros
VITE_FIREBASE_STATUS_DOCUMENT=status
